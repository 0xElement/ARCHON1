#!/bin/sh
# ARCHON pre-commit hook — block secrets, PII, and client data from ever being committed.
# Enable once per clone (also done by `npm run setup`):
#   git config core.hooksPath .githooks
#
# Scans only STAGED changes. Bypass a genuine false positive with a trailing `scan-allow`
# comment on the line, or (last resort) `git commit --no-verify`.
root="$(git rev-parse --show-toplevel)"
exec node "$root/scripts/scan-secrets.js" --staged
