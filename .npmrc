# legacy-peer-deps=true ensures npm ci reproduces the installed tree without
# errors from the @anthropic-ai/sdk version mismatch:
#   base @anthropic-ai/sdk is pinned at 0.88.0 (below agent-sdk's peer >=0.93.0)
# Safe because the sdk adapter never imports the base SDK directly — all model
# work runs through the bundled claude CLI. See sdk.js header for full rationale.
legacy-peer-deps=true
