{
  "name": "archon",
  "version": "1.0.0",
  "description": "ARCHON — autonomous AI web-application penetration testing. White-box (source) + black-box (live) in one engagement, with independent verification, operator triage, and a merged report.",
  "main": "event-bus.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ghostshift-content/ARCHON.git"
  },
  "homepage": "https://github.com/ghostshift-content/ARCHON#readme",
  "bugs": {
    "url": "https://github.com/ghostshift-content/ARCHON/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bootstrap": "bash setup.sh",
    "setup": "node scripts/setup-local.js",
    "start": "node event-bus.js",
    "dashboard": "node scripts/dashboard.js",
    "pretest": "node scripts/setup-local.js || true",
    "test": "node test/run-all.js",
    "scan": "node scripts/scan-secrets.js",
    "benchmark": "node benchmark/run-benchmark.js",
    "test:ui": "bash scripts/e2e.sh",
    "test:bun": "bun test",
    "pack:release": "git archive --format=zip -o archon-release.zip HEAD && echo 'clean release ZIP -> archon-release.zip (no node_modules / .git / .env.local)'"
  },
  "keywords": [
    "pentest",
    "penetration-testing",
    "appsec",
    "security",
    "white-box",
    "black-box",
    "code-review",
    "ai-agents",
    "llm",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.162",
    "acorn": "^8.16.0"
  },
  "optionalDependencies": {
    "playwright": "^1.59.1"
  }
}
