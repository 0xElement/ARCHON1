# ARCHON local environment.
# Copy to .env.local (gitignored) and adjust. paths.js autoloads .env.local at
# require time, so the daemon, dashboard, and spawned subprocesses all pick it up
# automatically. Real shell env vars take precedence over this file.

# Code root (where event-bus.js, paths.js, squads/ live) — usually the repo dir.
KURU_AGENTS_ROOT=/absolute/path/to/archon

# Data-layer root (runtime state). Keep it under the gitignored var/ dir so state
# never pollutes the repo. `npm run setup` seeds it.
KURU_INTEL_ROOT=/absolute/path/to/archon/var/intel

# Path to the Claude CLI the agents spawn. ARCHON uses your Claude subscription
# via OAuth (~/.claude) — NOT an API key. Point this at your local `claude` binary.
KURU_CLAUDE_BIN=/home/you/.local/bin/claude

# Subscription-only lock (optional). When set, ARCHON NEVER injects an API key for
# any agent — even if ANTHROPIC_API_KEY is in your env or a saved config — so every
# run authenticates with your Claude subscription via OAuth and can never fall
# through to metered API billing. Leave unset to allow an API key if you want one.
# ARCHON_SUBSCRIPTION_ONLY=1
